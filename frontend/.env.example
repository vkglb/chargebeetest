# Frontend (React/Vite) environment — copy to .env.local for local dev.
# Vite only exposes vars prefixed with VITE_.

# Base URL of the backend API.
# - Local dev: leave EMPTY (Vite proxies /v1 -> http://localhost:8080).
# - Production static site: set to the deployed API URL, e.g.
#   VITE_API_BASE=https://chargeebee-api.onrender.com
VITE_API_BASE=
