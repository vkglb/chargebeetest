# Copy to .env and fill in. Never commit real secrets.
APP_ENV=development
HTTP_ADDR=:8080
DATABASE_URL=postgres://chargeebee:chargeebee@localhost:5432/chargeebee?sslmode=disable
SHUTDOWN_TIMEOUT_SECONDS=15

# Stripe (platform-level; per-merchant Connect tokens are stored in the DB)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# SendGrid
SENDGRID_API_KEY=

# Auth
JWT_SECRET=dev-insecure-secret-change-me
