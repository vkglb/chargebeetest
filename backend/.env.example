# Backend (Go API) environment — copy to .env for local dev.
# Same variables are set per-service on Render (see render.yaml) or any host.
# Never commit real secrets.

# Runtime
APP_ENV=development              # development | production
HTTP_ADDR=:8080                  # ignored if PORT is set (Render/PaaS inject PORT)
SHUTDOWN_TIMEOUT_SECONDS=15

# Database (use the platform's connection string in prod)
DATABASE_URL=postgres://chargeebee:chargeebee@localhost:5432/chargeebee?sslmode=disable
AUTO_MIGRATE=false               # true = run migrations on startup (set true on Render)

# Auth
JWT_SECRET=dev-insecure-secret-change-me

# URLs / CORS
CHECKOUT_BASE_URL=http://localhost:5173   # where hosted checkout links point (the dashboard)
CORS_ORIGINS=*                            # comma-separated allowed origins, or * (tighten in prod)

# Payment gateway (per-merchant tokens live in the DB; this is platform-level)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
SENDGRID_API_KEY=
